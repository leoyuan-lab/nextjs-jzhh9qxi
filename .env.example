# Resend (inquiry form → info@roooll.com)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Roooll <info@roooll.com>
INQUIRY_TO_EMAIL=info@roooll.com

# Site URL (sitemap, metadata; use https://roooll.com in production)
NEXT_PUBLIC_SITE_URL=https://nextjs-jzhh9qxi.vercel.app

# Google Analytics 4 (optional — leave empty to disable; loads only after cookie consent)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# LinkedIn Insight Tag partner ID (optional — B2B ads; loads only after cookie consent)
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# Sentry (optional — run: npm install @sentry/nextjs, then set DSN)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
